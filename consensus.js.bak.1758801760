// consensus.js (forced Mary-judge version)
// 目的: パネル(Melchior/Gemini, Balthasar/Claude, Casper/Grok)の回答を集約し、
//       Mary(GPT)が「候補を根拠」に最終採択する。judge=null を二度と出さない。

const { getPanel, getJudge } = require('./providers/registry');

// 簡易合意率（全く同じテキストが何割か）
function normalize(s) {
  return String(s || '').trim().toLowerCase().replace(/\s+/g, ' ');
}
function agreementRatio(responses) {
  if (!responses?.length) return 0;
  const base = normalize(responses[0].text);
  const agree = responses.filter(r => normalize(r.text) === base).length;
  return agree / responses.length;
}

// Mary 用プロンプト（ユーザー質問は「参考のみ」、結論は候補内から）
function buildMaryPromptReferenceOnly(userPrompt, responses, metrics = {}) {
  const lines = responses.map(r => `- ${r.name || r.provider}: ${r.text}`).join('\n');
  return `
あなたは「Mary」という審判です。あなたの唯一の役割は、下記の候補回答のみを根拠に、中立に最終結論を採択することです。
禁止: あなた自身の新情報・独自意見の追加、裏取りのない推測。
許可: 候補の要点統合（候補内の内容に限定）。ユーザー質問は参照用であり、結論は必ず候補回答の範囲から選択／統合してください。

【参考（質問文。参照のみ／根拠化禁止）】
${userPrompt || '(なし)'}

【候補回答（根拠として使用可）】
${lines}

【参考メトリクス（任意参照）】
- 合意率: ${metrics.agreementRatio ?? 'N/A'}

出力は必ず JSON のみ:
{
 "final_answer": "...",            // 候補から選択 or 候補内の要点を統合
 "reason": "...",                  // どの候補のどの根拠か（候補名を明記）
 "confidence": "high|medium|low"
}
`.trim();
}

module.exports = async function consensus(userPrompt, meta = {}) {
  const panel = getPanel();
  const judge = getJudge();

  // 1) パネル問い合わせ（ユーザープロンプトはそのまま。必要なら redact は上位で）
  const responses = await Promise.all(panel.map(async p => {
    const r = await p.provider.call({ prompt: userPrompt, meta });
    return { name: p.name, llm: p.llm, text: r.text, model: r.model || p.llm, raw: r };
  }));

  // 2) 合意率など（簡易）
  const aRatio = agreementRatio(responses);

  // 3) Mary 最終採択（ユーザー質問は参考のみ。結論は候補内から）
  const jp = buildMaryPromptReferenceOnly(userPrompt, responses, { agreementRatio: aRatio });
  const maryResp = await judge.provider.call({ prompt: jp, meta: { temperature: 0 } });

  // 4) Mary 応答 JSON をパース（壊れてても落とさない）
  let mary = {};
  let maryText = (maryResp && maryResp.text) ? maryResp.text : String(maryResp || '');
  try { mary = JSON.parse(maryText); }
  catch {
    mary = { final_answer: null, reason: 'Mary JSON parse failed', confidence: null, raw: maryText };
  }

  // 5) 返却（互換のため final も残す）
  return {
    final: mary.final_answer || mary.answer || null,
    final_answer: mary.final_answer || mary.answer || null,
    reason: mary.reason || null,
    confidence: mary.confidence || null,
    judge: 'Mary',
    candidates: responses.map(r => ({ provider: r.name, text: r.text })),
    metrics: { agreement_ratio: aRatio }
  };
};
