const MODEL = process.env.ANTHROPIC_MODEL || 'claude-3-5-sonnet-20240620';
const API_KEY = process.env.ANTHROPIC_API_KEY;
if (!API_KEY) console.warn('[anthropic] ANTHROPIC_API_KEY not set');

async function call({ prompt, temperature = 0.2 }) {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'content-type': 'application/json',
      'x-api-key': API_KEY,
      'anthropic-version': '2023-06-01'
    },
    body: JSON.stringify({
      model: MODEL,
      max_tokens: 1024,
      temperature,
      messages: [{ role: 'user', content: prompt }]
    })
  });
  const j = await res.json();
  const text = j?.content?.map(p=>p?.text).join('') || j?.content?.[0]?.text || '';
  return { provider: 'anthropic', text: String(text || '') };
}

module.exports = { name: 'anthropic', call };
